---
import Layout from '../../layouts/Layout.astro';

const prefaceModule = await import('../../content/jp/00-preface.mdx');
const Preface = prefaceModule.default;

const posts = Object.values(
    import.meta.glob('../../content/jp/story/*.mdx', { eager: true })
)

const items = Object.values(
    import.meta.glob('../../content/jp/rabithole/*.mdx', { eager: true })
)

  .filter((post: any) => post.frontmatter?.slug)
  .sort((a: any, b: any) => {
    return (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999);
  });
---

<Layout title="国東界隈">
  <main>
    <header class="site-top">
    <div class="top-row">
    </div>
    </header>
    <h2>国東物語</h2>
    <div class="preface">
        <Preface />
    </div>

    <h3>もくじ</h3>
    <ol class="toc">
      {posts.map((post: any) => (
        <li>
          <a href={`/jp/story/${post.frontmatter.slug}/`}>
            {post.frontmatter.title}
          </a>
        </li>
      ))}
    </ol>

    <h2>国東ねほりはほり</h2>

    <h4>
    Coming Soon
    </h4>
    <ol class="toc">
      {items.map((item: any) => (
        <li>
          <a href={`/jp/rabithole/${item.frontmatter.slug}/`}>
            {item.frontmatter.title}
          </a>
        </li>
      ))}
    </ol>
    
    <h2>国東愛検定</h2>
　　 <div>
        あなたの国東愛がさくっとわかる
        <a href={`/jp/kunisakiology`}>
        検定試験
        </a>
        に挑戦<br>
    </div>
  </main>
</Layout>

<style>
    .preface :global(p) {
    margin: 0.3rem 0;
    line-height: 1.4;
    }

    .top-row {
    display: flex;
    justify-content: space-between;
    align-items: start;
    }

    .site-logo a {
    text-decoration: none;
    color: inherit;
    }

    .title-ja {
    font-size: 2rem;
    font-weight: bold;
    }

    .title-en {
    font-size: 1rem;
    color: #666;
    }

    .lang-switch {
    padding-top: 0.5rem;
    font-size: 0.9rem;
    }

</style>