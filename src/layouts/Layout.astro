---
const { title, lang = "jp", font } = Astro.props;
const isEn = lang === "en";
// font="reading" => serif (en) / mincho (jp); otherwise => sans (en) / gothic (jp)
const reading = font === "reading" || font === "mincho";
const bodyClass = isEn
  ? reading
    ? "en-serif"
    : "en-sans"
  : reading
    ? "ja-mincho"
    : "ja-gothic";
const base = isEn ? "/en" : "/jp";
const htmlLang = isEn ? "en" : "ja";
const pageTitle = title ?? "国東界隈";

const nav = isEn
  ? [
      { href: `${base}/`, label: "Home" },
      { href: `${base}/feel/`, label: "Feel Kunisaki" },
      { href: `${base}/`, label: "Learn Kunisaki" },
      { href: `${base}/walk/`, label: "Walk Kunisaki" },
      { href: `${base}/kunisakiology/`, label: "Kunisaki Love Test" },
      { href: `${base}/community/`, label: "Community" },
      { href: `${base}/about/`, label: "About" },
    ]
  : [
      { href: `${base}/`, label: "ホーム" },
      { href: `${base}/feel/`, label: "国東を感じる" },
      { href: `${base}/`, label: "国東を知る" },
      { href: `${base}/walk/`, label: "国東を歩く" },
      { href: `${base}/kunisakiology/`, label: "国東愛検定" },
      { href: `${base}/community/`, label: "コミュニティ" },
      { href: `${base}/about/`, label: "サイト情報" },
    ];
---

<!doctype html>

    <html lang={htmlLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{pageTitle}</title>
    </head>

    <body class={bodyClass}>
    <header class="site-top">
        <div class="top-bar">
            <div class="site-logo">
                <a href={`${base}/`}>
                    <img
                        src="/images/logo/kunisaki-kaiwai_logo4.png"
                        alt="国東界隈 Kunisaki Kaiwai"
                        class="logo-img"
                    />
                </a>
            </div>

            <div class="top-right">
                <div class="lang-switch">
                    <a href="/jp/">日本語</a> |
                    <a href="/en/">English</a>
                </div>

                <nav class="main-menu">
                    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
                </nav>
            </div>
        </div>
    </header>


    <header class="site-header">
        <a href={`${base}/`}>
        <img src="/images/Header.png" alt="Kunisaki Peninsula" />
        </a>
    </header>

    <div class="container">
        <slot />
    </div>
    </body>



    <hr class="footer-divider">
    <footer class="site-footer">
    <div class="footer-inner">

        <div class="footer-title">
        <h3>国東界隈 | Kunisaki Kaiwai</h3>
        </div>

        <nav class="footer-links">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>

        <p class="copyright">
        © 2026 Kunisaki Kaiwai
        </p>

        </div>
    </footer>

</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
  }

  /* English story / top pages: reading serif for body, sans for UI */
  body.en-serif {
    font-family: Georgia, Cambria, "Times New Roman", "Hiragino Mincho ProN",
      "Yu Mincho", "Noto Serif JP", serif;
    line-height: 1.7;
    color: #1a1a1a;
  }

  body.en-serif .main-menu,
  body.en-serif .footer-links,
  body.en-serif .lang-switch,
  body.en-serif .title-en,
  body.en-serif .copyright {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue",
      Arial, "Hiragino Sans", "Yu Gothic", "Noto Sans JP", sans-serif;
  }

  /* Other English pages (quiz, community, etc.): modern sans */
  body.en-sans {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue",
      Arial, "Hiragino Sans", "Yu Gothic", "Noto Sans JP", sans-serif;
    line-height: 1.7;
    color: #1a1a1a;
  }

  /* Japanese story / top pages: Mincho for reading, gothic for UI */
  body.ja-mincho {
    font-family: "Hiragino Mincho ProN", "Hiragino Mincho Pro", "Yu Mincho",
      YuMincho, "Noto Serif JP", "MS Mincho", serif;
    line-height: 1.9;
    color: #1a1a1a;
  }

  body.ja-mincho .main-menu,
  body.ja-mincho .footer-links,
  body.ja-mincho .lang-switch,
  body.ja-mincho .title-en,
  body.ja-mincho .copyright {
    font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans",
      "Hiragino Kaku Gothic ProN", "Yu Gothic", YuGothic, "Noto Sans JP",
      Meiryo, sans-serif;
  }

  /* Other Japanese pages (quiz, community, etc.): modern gothic */
  body.ja-gothic {
    font-family: -apple-system, BlinkMacSystemFont, "Hiragino Sans",
      "Hiragino Kaku Gothic ProN", "Yu Gothic", YuGothic, "Noto Sans JP",
      Meiryo, sans-serif;
    line-height: 1.8;
    color: #1a1a1a;
  }

  .site-top {
    padding: 1rem 2rem;
    border-bottom: 1px solid #ddd;
  }

  /* Logo on the left; a right column holds the language switch on the top
     row and the menu bar below it, aligned to the logo's bottom edge. */
  .top-bar {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
  }

  .top-right {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .site-logo a {
    text-decoration: none;
    color: inherit;
  }

  .logo-img {
    height: 130px;
    width: auto;
    display: block;
  }

  @media (max-width: 640px) {
    .top-bar {
      flex-wrap: wrap;
      align-items: flex-end;
    }

    .logo-img {
      height: 80px;
    }
  }

  .title-ja {
    font-size: 2rem;
    font-weight: bold;
  }

  .title-en {
    font-size: 1rem;
    color: #666;
  }

  .lang-switch {
    font-size: 0.9rem;
    align-self: flex-end;
  }

  .main-menu {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.5rem 1rem;
    margin: 0;
    font-size: 1.0rem;
  }

  .main-menu a {
    text-decoration: underline;
    color: #333;
  }

  .site-header {
    height: 250px;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .site-header img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2.5rem;
    font-size: 1.2rem;
  }

    .footer-divider {
    border: 0;
    border-top: 2px solid #666;
    margin: 3rem 0 2rem 0;
    }

.footer-inner {
  max-width: 860px;
  margin: 0 auto;
  text-align: center;
}

.footer-title h3 {
  margin: 0;
  line-height: 1.2;
}

.footer-title p {
  margin: 0.2rem 0 0;
  line-height: 1.2;
  font-size: 1.2rem;
  color: #666;
}

.footer-links {
  margin: 1rem 0 0.8rem;
}

.footer-links a {
  margin: 0.3rem;
  text-decoration: none;
  font-size: 1.0rem;
}

.footer-message {
  margin: 0.5rem 0;
  line-height: 1.3;
  font-size: 1.2rem;
  color: #666;
}

.copyright {
  margin: 0.5rem 0 0;
  font-size: 0.8rem;
  color: #999;
}
</style>
